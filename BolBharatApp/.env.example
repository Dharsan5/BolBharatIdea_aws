AWS_REGION=eu-north-1

# API base URL (Lambda URL or API Gateway)
API_GATEWAY_URL=https://your-endpoint.lambda-url.eu-north-1.on.aws/
DB_LAMBDA_URL=https://your-endpoint.lambda-url.eu-north-1.on.aws/
EXPO_PUBLIC_API_GATEWAY_URL=https://your-endpoint.lambda-url.eu-north-1.on.aws/
EXPO_PUBLIC_DB_LAMBDA_URL=https://your-endpoint.lambda-url.eu-north-1.on.aws/
EXPO_PUBLIC_AWS_REGION=eu-north-1

# Cognito (non-secret identifiers, still keep in env)
COGNITO_USER_POOL_ID=eu-north-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_OAUTH_DOMAIN=your-domain.auth.eu-north-1.amazoncognito.com

# Storage
S3_BUCKET_NAME=your-s3-bucket

NODE_ENV=development
